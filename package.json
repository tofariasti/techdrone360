{
  "name": "techdrone360",
  "version": "1.0.0",
  "description": "Landing page TechDrone360 - fotos e vídeos aéreos com drone",
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/input.css -o ./assets/css/output.css --minify",
    "build:seo": "node scripts/build-seo.mjs",
    "build:i18n": "node scripts/build-i18n.mjs",
    "build:leads": "node scripts/build-leads-html.mjs",
    "build": "npm run build:css && npm run build:seo && npm run build:i18n && npm run build:leads",
    "watch:css": "tailwindcss -i ./assets/css/input.css -o ./assets/css/output.css --watch"
  },
  "devDependencies": {
    "marked": "^18.0.5",
    "tailwindcss": "^3.4.17"
  }
}
