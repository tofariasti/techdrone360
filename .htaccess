# TechDrone360 — pastas e arquivos que não devem ser públicos em produção
# (Apache / Hostinger; inclua este arquivo na raiz de public_html)

<IfModule mod_rewrite.c>
  RewriteEngine On

  # www → domínio canônico (sem www)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # HTTP → HTTPS (complementa "Force HTTPS" do hPanel)
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # /leads → /leads/ (abre index.html via DirectoryIndex em leads/.htaccess)
  RewriteRule ^leads$ /leads/ [R=301,L]

  RewriteRule ^scripts(/.*)?$ - [F,L]
  RewriteRule ^node_modules(/.*)?$ - [F,L]
</IfModule>

# Bloqueia listagem de diretórios na raiz (se o servidor permitir Options)
<IfModule mod_autoindex.c>
  Options -Indexes
</IfModule>
