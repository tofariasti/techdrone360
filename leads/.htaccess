# TechDrone360 — área comercial interna (sem indexação — ver robots.txt e X-Robots-Tag abaixo)

DirectoryIndex index.html
Options -Indexes +FollowSymLinks

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /leads/

  # Garante index.html ao acessar /leads/
  RewriteRule ^$ index.html [L]
</IfModule>

# Fonte Markdown — leitura via HTML gerado (npm run build:leads)
<FilesMatch "\.md$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# Impede acesso direto ao arquivo de senhas (se estiver nesta pasta)
<Files ".htpasswd">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</Files>

<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, nofollow"
</IfModule>
